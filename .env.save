# ===== JWT AUTH =====
JWT_SECRET=cok_gizli_bir_anahtar_buraya_yaz
JWT_EXPIRES_IN=7d

# ===== META WhatsApp API =====
META_ACCESS_TOKEN=your_meta_access_token
META_PHONE_NUMBER_ID=your_phone_number_id
META_VERIFY_TOKEN=your_verify_token_random_string

# ===== AI PROVIDER =====
# auto: META_AI_API_KEY varsa Meta'yı, yoksa Claude'u dener
# meta: sadece Meta API kullanır
# anthropic: sadece Claude kullanır
AI_PROVIDER=auto

# ===== META AI API (Primary) =====
META_AI_API_KEY=your_meta_ai_api_key
META_AI_BASE_URL=https://api.llama.com/compat/v1
META_AI_MODEL=Llama-4-Maverick-17B-128E-Instruct
AI_REQUEST_TIMEOUT_MS=30000

# Maliyet optimizasyonu
# Sohbette son kac mesajin modele gonderilecegi (dusuk = daha ucuz)
AI_CONVERSATION_HISTORY_LIMIT=4
# Basit taleplerde AI cagrisi yapmadan yerel kural analizi kullan
AI_HEURISTIC_REQUEST_PARSING=true
AI_HEURISTIC_FEEDBACK_PARSING=true
# false ise randevu ozetini AI yerine yerel metinle olusturur (en ucuz)
AI_SUMMARY_WITH_MODEL=false

# ===== CLAUDE AI API (Optional fallback) =====
CLAUDE_API_KEY=sk-ant-yourapikey
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ===== MONGODB =====
MONGODB_URI=mongodb://localhost:27017/berber_randevu

# ===== SERVER CONFIGURATION =====
PORT=3000
NODE_ENV=development

# ===== BUSINESS HOURS (24-hour format) =====
BUSINESS_HOURS_START=10
BUSINESS_HOURS_END=20

# ===== GOOGLE CALENDAR API (Optional) =====
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ===== ELEVENLABS (Optional for voice) =====
ELEVENLABS_API_KEY=your_elevenlabs_key
